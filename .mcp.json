{
  "mcpServers": {
    "shadcn": {
      "command": "bunx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "rn-debugger": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "react-native-ai-debugger"
      ],
      "env": {}
    },
    "obsidian": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@mauricio.wolff/mcp-obsidian@latest",
        "/Users/vaibhavsharma/Documents/Obsidian Vault"
      ],
      "env": {}
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    }
  }
}
