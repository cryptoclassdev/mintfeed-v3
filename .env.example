# Database (Supabase Postgres) - Connection pooler
DATABASE_URL="postgresql://postgres.YOUR_REF:password@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_REF:password@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# CoinGecko
COINGECKO_API_URL="https://api.coingecko.com/api/v3"

# Jupiter Prediction Markets
JUPITER_API_KEY="your-jupiter-api-key"
PREDICTION_MIN_TRADE_USD=1

# Twitter / X API
TWITTER_BEARER_TOKEN="your-twitter-bearer-token"

# Server
PORT=3000
SOLANA_RPC_URL="https://your-rpc-provider.example.com"

# Mobile
EXPO_PUBLIC_SOLANA_RPC_URL="https://your-rpc-provider.example.com"

# Staging: copy this file to .env.staging and fill in staging Supabase URLs.
# Use `railway run` to inject staging vars when running locally.
