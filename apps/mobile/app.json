{
  "expo": {
    "name": "MintFeed",
    "slug": "mintfeed",
    "version": "1.0.0",
    "scheme": "mintfeed",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#030303"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mintfeed.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030303"
      },
      "package": "com.mintfeed.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "mintfeed" }],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
