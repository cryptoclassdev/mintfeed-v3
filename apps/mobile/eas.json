{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "staging": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "channel": "staging",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mintfeed-api-staging.up.railway.app",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "staging"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mintfeed-api-production.up.railway.app",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mintfeed-api-production.up.railway.app",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "production"
      }
    }
  }
}
