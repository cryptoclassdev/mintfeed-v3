datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Category {
  CRYPTO
  AI
}

enum SourceType {
  RSS
  TWITTER
}

enum TwitterSourceTier {
  TIER_1 // Always show
  TIER_2 // Show if engagement threshold met
  TIER_3 // Background context only
}

model Article {
  id                 String                    @id @default(cuid())
  sourceUrl          String                    @unique
  sourceUrlHash      String                    @unique
  titleHash          String?
  sourceName         String
  category           Category
  originalTitle      String
  originalBody       String                    @db.Text
  title              String
  summary            String                    @db.Text
  imageUrl           String?
  imageBlurhash      String?
  isBreaking         Boolean                   @default(false)
  sourceType         SourceType                @default(RSS)
  tweetId            String?                   @unique
  publishedAt        DateTime
  fetchedAt          DateTime                  @default(now())
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  predictionMarkets  ArticlePredictionMarket[]

  @@index([category, publishedAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
  @@index([titleHash])
}

model MarketCoin {
  id             String   @id
  symbol         String
  name           String
  currentPrice   Float
  priceChange24h Float
  marketCap      Float
  imageUrl       String?
  updatedAt      DateTime @updatedAt

  @@index([symbol])
}

model PredictionMarket {
  id            String                    @id // Jupiter marketId
  eventId       String                    // Jupiter parent event ID
  question      String
  outcomePrices Json                      // {"Yes": 0.73, "No": 0.27}
  outcomes      Json                      // ["Yes", "No"]
  liquidity     Float
  volume        Float
  endDate       DateTime?
  imageUrl      String?
  marketUrl     String                    // Jupiter prediction page URL
  closed        Boolean                   @default(false)
  category      String?                   // "crypto", "tech", etc.
  result        String?                   // null, "yes", "no"
  updatedAt     DateTime                  @updatedAt
  createdAt     DateTime                  @default(now())
  articles      ArticlePredictionMarket[]

  @@index([eventId])
  @@index([closed])
}

model ArticlePredictionMarket {
  id                 String           @id @default(cuid())
  articleId          String
  predictionMarketId String
  createdAt          DateTime         @default(now())
  article            Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  predictionMarket   PredictionMarket @relation(fields: [predictionMarketId], references: [id], onDelete: Cascade)

  @@unique([articleId, predictionMarketId])
  @@index([articleId])
  @@index([predictionMarketId])
}

// ─── Push Notifications ───

enum NotificationType {
  MARKET_MOVER
  BREAKING_NEWS
  PREDICTION_SETTLED
}

model PushDevice {
  id              String                  @id @default(cuid())
  expoPushToken   String                  @unique
  walletAddress   String?
  platform        String?                 // "ios" | "android"
  timezoneOffset  Int                     @default(0) // UTC offset in minutes
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  preferences     NotificationPreference?
  logs            NotificationLog[]

  @@index([walletAddress])
  @@index([isActive])
}

model NotificationPreference {
  id                 String     @id @default(cuid())
  deviceId           String     @unique
  device             PushDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  marketMovers       Boolean    @default(true)
  breakingNews       Boolean    @default(true)
  predictionSettled  Boolean    @default(true)
  quietHoursStart    Int        @default(23) // 0-23, device local time
  quietHoursEnd      Int        @default(7)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model NotificationLog {
  id             String           @id @default(cuid())
  deviceId       String
  device         PushDevice       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type           NotificationType
  title          String
  body           String
  referenceId    String?          // articleId, coinId, or marketId
  expoReceiptId  String?
  sentAt         DateTime         @default(now())

  @@index([deviceId, sentAt(sort: Desc)])
  @@index([deviceId, type, sentAt(sort: Desc)])
  @@index([referenceId])
}

model CoinPriceSnapshot {
  id      String   @id @default(cuid())
  coinId  String
  price   Float
  takenAt DateTime @default(now())

  @@index([coinId, takenAt(sort: Desc)])
}

// ─── Feed Sources ───

model FeedSource {
  id          String    @id @default(cuid())
  url         String    @unique
  name        String
  category    Category
  isActive    Boolean   @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model TwitterSource {
  id              String            @id @default(cuid())
  handle          String            @unique
  displayName     String
  profileImageUrl String?
  userId          String?
  tier            TwitterSourceTier @default(TIER_2)
  category        Category
  isActive        Boolean           @default(true)
  lastFetchAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}
